@page
@model RagFlowApi.Pages.RegisterModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_Layout";
}

<div class="users-shell">

    <header class="docs-header">
        <div>
            <h1 class="docs-title">Manage Users</h1>
            <p class="docs-subtitle">@Model.Users.Count account@(Model.Users.Count == 1 ? "" : "s")</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.FeedbackMsg))
    {
        <div class="alert @(Model.FeedbackOk ? "alert--success" : "alert--error")" style="margin-bottom:16px">
            @(Model.FeedbackOk ? "✓" : "⚠") @Model.FeedbackMsg
        </div>
    }

    @* ── User list ───────────────────────────────────────────────────── *@
    @if (Model.Users.Any())
    {
        <div class="docs-table-wrap" style="margin-bottom:32px">
            <table class="docs-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Display name</th>
                        <th>Full name</th>
                        <th>Department</th>
                        <th>Job title</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td><code>@u.Username</code></td>
                            <td>@u.DisplayName</td>
                            <td>@(string.IsNullOrEmpty(u.FullName) ? "—" : u.FullName)</td>
                            <td>@(string.IsNullOrEmpty(u.Department) ? "—" : u.Department)</td>
                            <td>@(string.IsNullOrEmpty(u.JobTitle) ? "—" : u.JobTitle)</td>
                            <td>@(string.IsNullOrEmpty(u.Email) ? "—" : u.Email)</td>
                            <td>
                                <span class="status-badge @(u.IsAdmin ? "status-done" : "status-unstart")">
                                    @(u.IsAdmin ? "Admin" : "User")
                                </span>
                            </td>
                            <td>
                                @if (!u.Username.Equals(User.Identity!.Name, StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post" asp-page-handler="Delete" class="inline-form"
                                          onsubmit="return confirm('Delete account &quot;@u.Username&quot;? This cannot be undone.');">
                                        <input type="hidden" name="username" value="@u.Username" />
                                        <button type="submit" class="btn-icon btn-icon--danger" title="Delete">🗑</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ── Create user form ─────────────────────────────────────────────── *@
    <div class="users-create-card">
        <h2 class="users-create-title">Create new account</h2>

        <form method="post" asp-page-handler="Create" class="users-create-form">

            <div class="users-section-label">Credentials</div>
            <div class="users-row">
                <div class="users-field">
                    <label>Username <span class="req">*</span></label>
                    <input type="text" name="newUsername" value="@Model.NewUsername"
                           placeholder="e.g. tung_vu" autocomplete="off" required />
                    <span class="users-hint">Letters, numbers, _ and - only.</span>
                </div>
                <div class="users-field">
                    <label>Display name</label>
                    <input type="text" name="newDisplayName" value="@Model.NewDisplayName"
                           placeholder="e.g. Tùng Vũ" autocomplete="off" />
                </div>
            </div>

            <div class="users-row">
                <div class="users-field">
                    <label>Password <span class="req">*</span></label>
                    <input type="password" name="newPassword" autocomplete="new-password"
                           placeholder="At least 6 characters" required />
                    <span class="users-hint">User can change it after first login.</span>
                </div>
                <div class="users-field users-field--check">
                    <label class="users-check-label">
                        <input type="checkbox" name="newIsAdmin" value="true" @(Model.NewIsAdmin ? "checked" : "") />
                        Admin privileges
                    </label>
                    <span class="users-hint">Admins can upload documents and manage users.</span>
                </div>
            </div>

            <div class="users-section-label" style="margin-top:20px">Profile (optional)</div>
            <div class="users-row">
                <div class="users-field">
                    <label>Full name</label>
                    <input type="text" name="newFullName" value="@Model.NewFullName"
                           placeholder="e.g. Nguyễn Tùng Vũ" autocomplete="off" />
                </div>
                <div class="users-field">
                    <label>Department</label>
                    <select name="newDepartment">
                        <option value="">— select —</option>
                        @foreach (var dept in new[]{"HR","DEV","TEST","BA","FINANCE"})
                        {
                            if (Model.NewDepartment == dept)
                            { <option value="@dept" selected>@dept</option> }
                            else
                            { <option value="@dept">@dept</option> }
                        }
                    </select>
                </div>
            </div>
            <div class="users-row">
                <div class="users-field">
                    <label>Job title</label>
                    <input type="text" name="newJobTitle" value="@Model.NewJobTitle"
                           placeholder="e.g. Software Engineer" autocomplete="off" />
                </div>
                <div class="users-field">
                    <label>Email</label>
                    <input type="email" name="newEmail" value="@Model.NewEmail"
                           placeholder="e.g. tung@company.vn" autocomplete="off" />
                </div>
            </div>
            <div class="users-row">
                <div class="users-field">
                    <label>Phone</label>
                    <input type="text" name="newPhone" value="@Model.NewPhone"
                           placeholder="e.g. 0901234567" autocomplete="off" />
                </div>
                <div class="users-field"></div>
            </div>

            <button type="submit" class="btn btn--primary" style="margin-top:8px">
                Create account
            </button>

        </form>
    </div>
</div>

<style>
    .users-shell {
        flex: 1;
        overflow-y: auto;
        padding: 32px 40px;
        width: 100%;
    }

    .users-shell > * {
        max-width: 1000px;
        margin-left: auto;
        margin-right: auto;
    }

    .users-create-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 32px;
    }

    .users-create-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 20px;
        color: var(--text-primary);
    }

    .users-section-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-muted);
        margin-bottom: 10px;
    }

    .users-create-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .users-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .users-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .users-field label {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .users-field input[type="text"],
    .users-field input[type="email"],
    .users-field input[type="password"],
    .users-field select {
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 9px 12px;
        font-family: var(--font);
        font-size: 13px;
        color: var(--text-primary);
        outline: none;
        transition: border-color .15s;
    }

    .users-field input:focus,
    .users-field select:focus {
        border-color: var(--border-focus);
    }

    .users-field--check {
        justify-content: center;
        padding-top: 4px;
    }

    .users-check-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }

    .users-hint {
        font-size: 11px;
        color: var(--text-muted);
    }

    .req { color: var(--error); }
</style>
