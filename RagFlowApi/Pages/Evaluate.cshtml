@page
@model RagFlowApi.Pages.EvaluateModel
@{
    ViewData["Title"] = "RAGAS Evaluation";
    Layout = "_Layout";
}

<style>
/* ── Evaluate shell — scrollable like docs page ────────────────────────── */
.eval-shell {
    flex: 1;
    overflow-y: auto;
    padding: 32px 40px 56px;
    width: 100%;
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font);
}

/* ── Header ────────────────────────────────────────────────────────────── */
.eval-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
}

.eval-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
}

.eval-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
    max-width: 640px;
    line-height: 1.5;
}

.eval-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-shrink: 0;
}

/* ── Summary cards ─────────────────────────────────────────────────────── */
.eval-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
}

.summary-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    text-align: center;
}

.summary-card__value {
    font-size: 32px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--accent);
    line-height: 1.1;
}
.summary-card__value--good { color: var(--success); }
.summary-card__value--mid  { color: #f5a623; }
.summary-card__value--bad  { color: var(--error); }
.summary-card__value--none { color: var(--text-muted); }

.summary-card__label {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 6px;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
}

/* ── Table wrapper ─────────────────────────────────────────────────────── */
.eval-table-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
}

.eval-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.eval-table thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-subtle);
    background: var(--bg-input);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}

.eval-table tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    vertical-align: top;
}

.eval-table tbody tr:last-child td {
    border-bottom: none;
}

.eval-table tbody tr:hover td {
    background: rgba(255,255,255,.02);
}

/* ── Column widths ─────────────────────────────────────────────────────── */
.col-id       { width: 48px; color: var(--text-muted); font-family: var(--font-mono); font-size: 12px; }
.col-question { max-width: 240px; font-weight: 500; font-size: 13px; }
.col-answer   { max-width: 300px; }
.col-chunks   { width: 70px; text-align: center; font-family: var(--font-mono); color: var(--text-muted); }
.col-score    { width: 130px; }
.col-gt       { max-width: 200px; color: var(--text-muted); font-size: 12px; }

.answer-preview {
    color: var(--text-muted);
    font-size: 12px;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* ── Score badges ──────────────────────────────────────────────────────── */
.score-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    font-family: var(--font-mono);
    min-width: 52px;
    text-align: center;
}

.score--high  { background: rgba(45,212,160,.15); color: var(--success); }
.score--mid   { background: rgba(245,166,35,.15);  color: #f5a623; }
.score--low   { background: rgba(247,111,111,.15); color: var(--error); }
.score--error { background: rgba(247,111,111,.08); color: var(--error);
                font-weight: 400; font-size: 11px; padding: 3px 6px; }

.reason-text {
    font-size: 11px;
    color: var(--text-subtle);
    margin-top: 4px;
    line-height: 1.4;
}

/* ── Empty state ───────────────────────────────────────────────────────── */
.eval-empty {
    padding: 64px 24px;
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
}

.eval-empty code {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
}

/* ── Secondary button ──────────────────────────────────────────────────── */
.btn--secondary {
    background: var(--bg-input);
    color: var(--text-primary);
    border: 1px solid var(--border);
}
.btn--secondary:hover {
    background: var(--bg-card);
    border-color: var(--border-focus);
    color: var(--text-primary);
}

.btn:disabled {
    opacity: .5;
    cursor: not-allowed;
    pointer-events: none;
}

/* ── Spinner ───────────────────────────────────────────────────────────── */
.spinner {
    display: inline-block;
    width: 13px; height: 13px;
    border: 2px solid rgba(255,255,255,.25);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
    flex-shrink: 0;
}
@@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="eval-shell">

    @* ── Header ────────────────────────────────────────────────────────────── *@
    <div class="eval-header">
        <div>
            <div class="eval-title">RAGAS Evaluation</div>
            <div class="eval-subtitle">
                Measures answer quality using Faithfulness and Answer Relevancy metrics.
                Each question creates a temporary RAGFlow session that is deleted after scoring.
            </div>
        </div>
        <div class="eval-actions">
            @if (Model.HasRun && Model.Results.Count > 0)
            {
                <form method="post" asp-page-handler="Export">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn--secondary">↓ Export CSV</button>
                </form>
            }
            <form method="post" asp-page-handler="Run" id="runForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn--primary" id="runBtn">
                    ▶ Run Evaluation
                    <span style="font-size:12px;opacity:.65;margin-left:2px">(@Model.Questions.Count questions)</span>
                </button>
            </form>
        </div>
    </div>

    @* ── Error banner ───────────────────────────────────────────────────────── *@
    @if (Model.ErrorMessage is not null)
    {
        <div class="alert alert--error" style="margin-bottom:20px;margin-left:0">
            ⚠ @Model.ErrorMessage
        </div>
    }

    @* ── Summary cards (only after a run) ──────────────────────────────────── *@
    @if (Model.HasRun && Model.Results.Count > 0)
    {
        var fa   = Model.AvgFaithfulness;
        var ar   = Model.AvgAnswerRelevancy;
        var ok   = Model.Results.Count(r => !r.HasError);
        var errs = Model.Results.Count(r => r.HasError);

        string ScoreClass(double v) =>
            v < 0 ? "none" : v >= 0.7 ? "good" : v >= 0.4 ? "mid" : "bad";

        <div class="eval-summary">
            <div class="summary-card">
                <div class="summary-card__value summary-card__value--@ScoreClass(fa)">
                    @(fa >= 0 ? fa.ToString("F2") : "—")
                </div>
                <div class="summary-card__label">Avg Faithfulness</div>
            </div>
            <div class="summary-card">
                <div class="summary-card__value summary-card__value--@ScoreClass(ar)">
                    @(ar >= 0 ? ar.ToString("F2") : "—")
                </div>
                <div class="summary-card__label">Avg Answer Relevancy</div>
            </div>
            <div class="summary-card">
                <div class="summary-card__value">@ok / @Model.Results.Count</div>
                <div class="summary-card__label">Questions Scored</div>
            </div>
            @if (errs > 0)
            {
                <div class="summary-card">
                    <div class="summary-card__value summary-card__value--bad">@errs</div>
                    <div class="summary-card__label">Errors</div>
                </div>
            }
        </div>
    }

    @* ── Table ─────────────────────────────────────────────────────────────── *@
    <div class="eval-table-wrap">
        @if (!Model.HasRun)
        {
            @* Pre-run: question preview *@
            @if (Model.Questions.Count == 0)
            {
                <div class="eval-empty">
                    No questions loaded. Add an <code>eval_questions.json</code> file to <code>wwwroot/</code>.
                </div>
            }
            else
            {
                <table class="eval-table">
                    <thead>
                        <tr>
                            <th class="col-id">#</th>
                            <th>Question</th>
                            <th style="width:120px;text-align:center">Ground Truth</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in Model.Questions)
                        {
                            <tr>
                                <td class="col-id">@q.Id</td>
                                <td class="col-question">@q.Question</td>
                                <td style="text-align:center">
                                    @if (q.GroundTruth is not null)
                                    {
                                        <span style="color:var(--success);font-size:12px">✓ set</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-subtle);font-size:12px">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else
        {
            @* Post-run: full results *@
            @if (Model.Results.Count == 0)
            {
                <div class="eval-empty">No results returned.</div>
            }
            else
            {
                <table class="eval-table">
                    <thead>
                        <tr>
                            <th class="col-id">#</th>
                            <th>Question</th>
                            <th>Answer</th>
                            <th class="col-chunks">Chunks</th>
                            <th class="col-score">Faithfulness</th>
                            <th class="col-score">Answer Relevancy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Results)
                        {
                            <tr>
                                <td class="col-id">@r.Id</td>

                                <td class="col-question">@r.Question</td>

                                <td class="col-answer">
                                    @if (r.HasError)
                                    {
                                        <span style="color:var(--error);font-size:12px">⚠ @r.ErrorMessage</span>
                                    }
                                    else
                                    {
                                        <div class="answer-preview">@r.Answer</div>
                                    }
                                </td>

                                <td class="col-chunks">@r.ChunkCount</td>

                                <td class="col-score">
                                    @if (r.Faithfulness is not null)
                                    {
                                        <span class="score-badge @r.Faithfulness.CssClass">@r.Faithfulness.Display</span>
                                        @if (!r.Faithfulness.IsError && !string.IsNullOrEmpty(r.Faithfulness.Reason))
                                        {
                                            <div class="reason-text">@r.Faithfulness.Reason</div>
                                        }
                                    }
                                    else { <span style="color:var(--text-muted)">—</span> }
                                </td>

                                <td class="col-score">
                                    @if (r.AnswerRelevancy is not null)
                                    {
                                        <span class="score-badge @r.AnswerRelevancy.CssClass">@r.AnswerRelevancy.Display</span>
                                        @if (!r.AnswerRelevancy.IsError && !string.IsNullOrEmpty(r.AnswerRelevancy.Reason))
                                        {
                                            <div class="reason-text">@r.AnswerRelevancy.Reason</div>
                                        }
                                    }
                                    else { <span style="color:var(--text-muted)">—</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

</div>

<script>
document.getElementById('runForm')?.addEventListener('submit', function () {
    var btn = document.getElementById('runBtn');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Running… this may take several minutes';
    }
});
</script>
