@inject RagFlowApi.Services.PendingDocumentStore PendingStore
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RAGFlow</title>
    <link rel="stylesheet" href="/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/account.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/chat.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/documents.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/chunks.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
@{
    var isAuth = Context.User.Identity?.IsAuthenticated == true;
    var isAdmin = Context.User.IsInRole("admin");
    var curPath = Context.Request.Path.Value?.ToLower() ?? "";
    var displayName = Context.User.FindFirst("DisplayName")?.Value
                      ?? Context.User.Identity?.Name
                      ?? "User";
    var initials = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName[0].ToString().ToUpper();
}
<body class="@(isAuth ? "" : "layout--no-sidebar")">

    <aside class="nav-sidebar" id="navSidebar">
        <div class="nav-brand-row">
            <button class="nav-toggle-btn" id="navToggleBtn" title="Toggle sidebar" aria-label="Toggle sidebar">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                    <rect y="2" width="16" height="2" rx="1"/>
                    <rect y="7" width="16" height="2" rx="1"/>
                    <rect y="12" width="16" height="2" rx="1"/>
                </svg>
            </button>
            <span class="nav-logo-icon">⬡</span>
            <span class="nav-title-text">RAGFlow</span>
        </div>

        @if (isAuth)
        {
            <nav class="nav-links-list">
                <a href="/Ask" class="nav-item @(curPath.StartsWith("/ask") ? "nav-item--active" : "")">
                    <span class="nav-item-icon">💬</span>
                    <span class="nav-item-label">Chat</span>
                </a>
                <a href="/Documents" class="nav-item @(curPath.StartsWith("/documents") ? "nav-item--active" : "")">
                    <span class="nav-item-icon">📄</span>
                    <span class="nav-item-label">Documents</span>
                </a>
                <a href="/FillForm" class="nav-item @(curPath.StartsWith("/fillform") ? "nav-item--active" : "")">
                    <span class="nav-item-icon">📋</span>
                    <span class="nav-item-label">Fill Form</span>
                </a>

                @if (isAdmin)
                {
                    var pendingCount = await PendingStore.GetPendingCountAsync();
                    <div class="nav-divider"></div>
                    <div class="nav-section-header">Admin</div>

                    <a href="/Pending" class="nav-item @(curPath.StartsWith("/pending") ? "nav-item--active" : "")">
                        <span class="nav-item-icon">🔎</span>
                        <span class="nav-item-label">Review</span>
                        @if (pendingCount > 0)
                        {
                            <span class="nav-badge">@pendingCount</span>
                        }
                    </a>
                    <a href="/Register" class="nav-item @(curPath.StartsWith("/register") ? "nav-item--active" : "")">
                        <span class="nav-item-icon">👤</span>
                        <span class="nav-item-label">Users</span>
                    </a>
                    <a href="/swagger" class="nav-item">
                        <span class="nav-item-icon">⚙</span>
                        <span class="nav-item-label">API</span>
                    </a>
                    <a href="/Evaluate" class="nav-item @(curPath.StartsWith("/evaluate") ? "nav-item--active" : "")">
                        <span class="nav-item-icon">📊</span>
                        <span class="nav-item-label">Evaluate</span>
                    </a>
                    <a href="/Benchmark" class="nav-item @(curPath.StartsWith("/benchmark") ? "nav-item--active" : "")">
                        <span class="nav-item-icon">⚡</span>
                        <span class="nav-item-label">Benchmark</span>
                    </a>
                }
            </nav>

            <div class="nav-user-section">
                <div class="nav-user-wrap" id="navUserWrap">
                    <button class="nav-user-btn" id="navUserBtn"
                            aria-haspopup="true" aria-expanded="false"
                            aria-controls="navUserDropdown" title="Account options">
                        <span class="nav-user-avatar">@initials</span>
                        <span class="nav-user-name">@displayName</span>
                        <span class="nav-user-chevron">▾</span>
                    </button>

                    <div class="nav-user-dropdown nav-user-dropdown--up" id="navUserDropdown" role="menu">
                        <button class="dropdown-item" id="openAccountModal" role="menuitem">
                            <span class="dropdown-item-icon">👤</span>
                            Profile
                        </button>
                        <div class="dropdown-divider"></div>
                        <form method="post" action="/logout" style="margin:0">
                            <button type="submit" class="dropdown-item dropdown-item--danger" role="menuitem">
                                <span class="dropdown-item-icon">🚪</span>
                                Sign out
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </aside>

    <div class="page-body">
        @RenderBody()
    </div>

    @* ── Account modal backdrop (hidden until opened) ────────────────────── *@
    <div class="modal-backdrop" id="accountBackdrop" aria-modal="true" role="dialog" aria-label="Account">
        <div class="modal-card" id="accountModal">
            <div class="modal-header">
                <span class="modal-title">Account</span>
                <button class="modal-close" id="closeAccountModal" aria-label="Close">✕</button>
            </div>
            <div class="modal-body" id="accountModalBody">
                @* Content fetched from /Account and injected here *@
                <div style="text-align:center;padding:20px;color:var(--text-muted);font-size:14px">
                    Loading…
                </div>
            </div>
        </div>
    </div>

    <script>
    (function () {
        // ── Sidebar collapse toggle ───────────────────────────────────────
        var sidebar    = document.getElementById('navSidebar');
        var toggleBtn  = document.getElementById('navToggleBtn');
        var COLLAPSED  = 'nav-sidebar--collapsed';
        var LS_KEY     = 'ragflow_sidebar_collapsed';

        if (sidebar && toggleBtn) {
            // Restore saved state before first paint
            if (localStorage.getItem(LS_KEY) === '1') {
                sidebar.classList.add(COLLAPSED);
            }

            toggleBtn.addEventListener('click', function () {
                var isNowCollapsed = sidebar.classList.toggle(COLLAPSED);
                localStorage.setItem(LS_KEY, isNowCollapsed ? '1' : '0');
            });
        }

        // ── Dropdown toggle ───────────────────────────────────────────────
        var btn       = document.getElementById('navUserBtn');
        var dropdown  = document.getElementById('navUserDropdown');
        var wrap      = document.getElementById('navUserWrap');

        if (btn && dropdown) {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = dropdown.classList.toggle('is-open');
                btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            });

            // Close when clicking outside
            document.addEventListener('click', function (e) {
                if (wrap && !wrap.contains(e.target)) {
                    dropdown.classList.remove('is-open');
                    btn.setAttribute('aria-expanded', 'false');
                }
            });

            // Close on Escape
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    dropdown.classList.remove('is-open');
                    btn.setAttribute('aria-expanded', 'false');
                }
            });
        }

        // ── Modal open / close ────────────────────────────────────────────
        var backdrop  = document.getElementById('accountBackdrop');
        var modalBody = document.getElementById('accountModalBody');
        var openBtn   = document.getElementById('openAccountModal');
        var closeBtn  = document.getElementById('closeAccountModal');
        var loaded    = false;   // only fetch once per page load

        function openModal() {
            if (dropdown) {
                dropdown.classList.remove('is-open');
                if (btn) btn.setAttribute('aria-expanded', 'false');
            }
            backdrop.classList.add('is-open');
            document.body.style.overflow = 'hidden';
            applyModalScroll();

            if (!loaded) {
                loaded = true;
                fetchAccountContent();
            }
        }

        window.addEventListener('resize', function () {
            if (backdrop?.classList.contains('is-open')) applyModalScroll();
        });

        function closeModal() {
            backdrop.classList.remove('is-open');
            document.body.style.overflow = '';
        }

        openBtn?.addEventListener('click', openModal);
        closeBtn?.addEventListener('click', closeModal);

        // Click backdrop (outside card) to close
        backdrop?.addEventListener('click', function (e) {
            if (e.target === backdrop) closeModal();
        });

        // Escape to close
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && backdrop?.classList.contains('is-open')) closeModal();
        });

        // ── Fetch /Account and inject content ────────────────────────────
        function fetchAccountContent(url) {
            var fetchUrl = url || '/Account';
            fetch(fetchUrl, { credentials: 'same-origin' })
                .then(function (r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.text();
                })
                .then(function (html) {
                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');
                    var fragment = doc.getElementById('account-modal-body');
                    if (!fragment) {
                        modalBody.innerHTML =
                            '<div style="color:var(--error);font-size:13px">Could not load account info.</div>';
                        return;
                    }
                    modalBody.innerHTML = fragment.innerHTML;
                    wireAccountModal();
                })
                .catch(function (err) {
                    modalBody.innerHTML =
                        '<div style="color:var(--error);font-size:13px">Error: ' + err.message + '</div>';
                });
        }

        // ── Constrain modal-body height so it scrolls ─────────────────────
        function applyModalScroll() {
            var header = document.querySelector('#accountModal .modal-header');
            var headerH = header ? header.offsetHeight : 62;
            var available = window.innerHeight - headerH - 40; // 40 = 2×backdrop padding
            modalBody.style.maxHeight = available + 'px';
            modalBody.style.overflowY = 'auto';
            modalBody.style.overscrollBehavior = 'contain';
        }

        // ── Wire everything inside the modal after any (re-)injection ─────
        function wireAccountModal(activeSection) {
            applyModalScroll();
            wireTabs(activeSection);
            wireAjaxForm('changePwForm',  '/Account?handler=ChangePassword',  'password');
            wireAjaxForm('profileForm',   '/Account?handler=UpdateProfile',   'profile');
        }

        // ── Tab switching ─────────────────────────────────────────────────
        function wireTabs(activeSection) {
            var tabs     = modalBody.querySelectorAll('.acct-tab');
            var sections = modalBody.querySelectorAll('.acct-section');

            tabs.forEach(function (tab) {
                tab.addEventListener('click', function () {
                    tabs.forEach(function (t) { t.classList.remove('acct-tab--active'); });
                    sections.forEach(function (s) { s.style.display = 'none'; });
                    tab.classList.add('acct-tab--active');
                    var target = modalBody.querySelector('#' + tab.dataset.tab);
                    if (target) target.style.display = '';
                });
            });

            // Activate the correct tab (server-supplied or default)
            var target = activeSection || 'passwordSection';
            var activeTab = modalBody.querySelector('[data-tab="' + target + '"]');
            if (activeTab) activeTab.click();
        }

        // ── Generic AJAX form submit, re-injects modal on success ─────────
        function wireAjaxForm(formId, url, sectionOnSuccess) {
            var form = modalBody.querySelector('#' + formId);
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                var submitBtn = form.querySelector('[type="submit"]');
                var origText  = submitBtn ? submitBtn.textContent : '';
                if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Saving…'; }

                fetch(url, {
                    method: 'POST',
                    body: new FormData(form),
                    credentials: 'same-origin'
                })
                .then(function (r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.text();
                })
                .then(function (html) {
                    var parser = new DOMParser();
                    var doc    = parser.parseFromString(html, 'text/html');
                    var frag   = doc.getElementById('account-modal-body');
                    if (frag) {
                        modalBody.innerHTML = frag.innerHTML;
                        wireAccountModal(sectionOnSuccess + 'Section');
                    }
                })
                .catch(function (err) {
                    var fb = modalBody.querySelector('#modal-feedback');
                    if (fb) {
                        fb.style.display = '';
                        fb.className = 'modal-alert modal-alert--error';
                        fb.textContent = '⚠ ' + err.message;
                    }
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = origText; }
                });
            });
        }
    })();
    </script>
</body>
</html>
